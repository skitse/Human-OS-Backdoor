# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# ── Anthropic / Anthropic-compatible ──────────────────────────────────────────
# API key (Anthropic native, or Kimi / any Anthropic-compatible provider)
ANTHROPIC_API_KEY=sk-ant-...

# Override base URL when using a compatible provider instead of Anthropic native.
# Kimi Code (Anthropic-compatible mode):
#   ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# Leave empty or unset to use Anthropic's default endpoint.
ANTHROPIC_BASE_URL=

# Model to use for the Anthropic provider.
# Kimi Code example: moonshot-v1-32k
# Anthropic default: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── OpenRouter (free models available) ────────────────────────────────────────
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Free model examples:
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemma-2-9b-it:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
